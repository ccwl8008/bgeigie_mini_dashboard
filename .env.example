# Copia este archivo a ".env" y llena los valores reales.
# NUNCA subas el ".env" real a git.

MYSQL_ROOT_PASSWORD=cambia_esto_root
MYSQL_DATABASE=cyber2sof_bGeigie
MYSQL_USER=cyber2sof_nano
MYSQL_PASSWORD=cambia_esto_password

# Clave para firmar las cookies de sesión (genera una larga y aleatoria)
# Ejemplo para generarla: openssl rand -hex 32
SECRET_KEY=cambia_esto_por_algo_largo_y_aleatorio

# Usuario admin que se crea automáticamente la primera vez que arranca
# el backend (si ya existe un usuario con este username, no se toca).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia_esta_clave
ADMIN_NOMBRE=Administrador
